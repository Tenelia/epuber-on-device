    "express": "^5.2.1",
    "fflate": "^0.8.3",
    "lucide-react": "^1.22.0",
    "marked": "^18.0.5",
    "motion": "^12.42.0",
    "openai": "^6.45.0",
    "react": "^19.2.7",
